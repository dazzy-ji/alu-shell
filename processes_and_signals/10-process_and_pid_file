#!/usr/bin/env bash
# Advanced process management with PID file and signal handling

PID_FILE="/var/run/myscript.pid"

# Write current PID to file
echo $$ > "$PID_FILE"

# Cleanup function — deletes PID file and exits
cleanup() {
    echo "I hate the kill command"
    rm -f "$PID_FILE"
    exit 0
}

# Signal handlers
trap 'cleanup' SIGTERM SIGQUIT
trap 'echo "Y U no love me?!"' SIGINT

# Main loop
while true; do
    echo "To infinity and beyond"
    sleep 2
done
